generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  createdAt     DateTime  @default(now())

  // Stripe課金（Web用）
  stripeCustomerId    String?
  subscriptionId      String?
  subscriptionStatus  String  @default("free") // free, trialing, active, canceling, canceled, past_due
  trialStartDate      DateTime @default(now())
  trialEndsAt         DateTime?
  billingStartDate    DateTime?
  nextBillingDate     DateTime?
  canceledAt          DateTime?

  // Apple課金（iOS用）
  appleOriginalTransactionId  String?   // Appleの取引ID
  appleSubscriptionStatus     String?   // active, expired, billing_retry, grace_period
  appleExpiresAt              DateTime? // 有効期限
  appleProductId              String?   // com.wansapo.premium.monthly

  // 統合課金フラグ（Stripe/Apple どちらでもOK）
  isPremium           Boolean @default(false)

  // ユーザータイプ
  userType      String?   // new_owner, reviewing

  // 設定
  onboarded     Boolean   @default(false)
  notificationEnabled Boolean @default(true)

  // 関連
  dogs          Dog[]
  walkHistories WalkHistory[]
  appleReceipts AppleReceipt[]
}

model Dog {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  imageUrl      String?
  breed         String?
  birthDate     DateTime?
  adoptedAt     DateTime?

  // 基本情報（拡張）
  dogSize       String?   // small, medium, large, unknown

  // ヒアリング結果（拡張）
  hasDisease        Boolean?
  diseaseDetail     String?
  visitFrequency    String?   // none, low, high, new_owner
  livingEnv         String?   // indoor, indoor_yard, outdoor
  walkFrequency     String?   // daily, often, sometimes, rarely
  isMultiDog        Boolean?  @default(false)
  multiDogCount     Int?      @default(1)
  anxietyLevel      Int?      // 1-5

  // 既存保険情報（見直しユーザー向け）
  hasCurrentInsurance Boolean?
  currentInsuranceCost String?  // ~1000, 1000-2000, 2000-3000, 3000+, unknown
  insuranceConcern    String?   // expensive, low_coverage, complicated, none

  // 旧フィールド（互換性のため残す）
  hasVisitedVet Boolean?
  mainConcern   String?

  // 健康管理
  lastVaccineDate   DateTime?
  lastRabiesDate    DateTime?
  lastCheckupDate   DateTime?

  // ワクチン
  vaccineSchedules VaccineSchedule[]
  notifications    Notification[]
  walkHistories    WalkHistory[]
  snsPosts         SnsPost[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VaccineSchedule {
  id            String    @id @default(cuid())
  dogId         String
  dog           Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)

  type          String    // mixed_vaccine, rabies, heartworm, checkup
  scheduledDate DateTime
  completedAt   DateTime?
  notifiedWeek  Boolean   @default(false)
  notifiedDay   Boolean   @default(false)
  completed     Boolean   @default(false)

  createdAt     DateTime  @default(now())
}

model Notification {
  id            String    @id @default(cuid())
  dogId         String
  dog           Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)

  type          String    // vaccine_reminder, rabies_reminder, checkup_reminder, heartworm_reminder, custom
  title         String
  body          String
  scheduledAt   DateTime
  sentAt        DateTime?

  createdAt     DateTime  @default(now())
}

model WalkHistory {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dogId         String
  dog           Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)

  startedAt     DateTime
  endedAt       DateTime?
  durationMin   Int?
  distanceM     Int?
  routePolyline String?

  createdAt     DateTime  @default(now())
}

model SnsPost {
  id            String    @id @default(cuid())
  dogId         String
  dog           Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)

  imageUrl      String
  caption       String
  hashtags      String    // JSON配列

  postedAt      DateTime?
  platform      String?   // instagram, twitter

  createdAt     DateTime  @default(now())
}

model InsuranceClick {
  id            String    @id @default(cuid())
  dogId         String

  insuranceId   String
  insuranceName String
  matchScore    Int?
  reason        String?
  rank          Int?

  clickedAt     DateTime  @default(now())
}

model GoodsItem {
  id            String    @id @default(cuid())
  title         String
  description   String
  imageUrl      String?
  category      String    // toy, food, care, fashion, outdoor
  price         Int?
  affiliateUrl  String?
  tags          String    // JSON配列

  publishedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
}

// ================================================
// 機能①：かかりつけ動物病院
// ================================================
model VetClinic {
  id            String    @id @default(cuid())

  // 病院情報
  name          String
  address       String
  phone         String?
  googleMapsUrl String?
  placeId       String?   // Google Places ID

  // 診療時間（JSON形式で保存）
  businessHours String?   // {"mon": "9:00-18:00", "tue": "9:00-18:00", ...}

  // 位置情報
  latitude      Float?
  longitude     Float?

  // メタ情報
  rating        Float?
  reviewCount   Int?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // かかりつけ登録
  primaryUsers  PrimaryVetClinic[]
}

model PrimaryVetClinic {
  id            String    @id @default(cuid())
  userId        String
  clinicId      String
  clinic        VetClinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  // 登録日
  registeredAt  DateTime  @default(now())

  // メモ（任意）
  memo          String?

  @@unique([userId])  // 1ユーザー1かかりつけ
}

// ================================================
// 機能②：ご近所ワンちゃん匿名コミュニティ
// ================================================
model CommunityPost {
  id            String    @id @default(cuid())
  userId        String    // 投稿者（非公開）

  // 匿名表示名（自動生成）
  anonymousName String    // "柴犬飼い主＠近所", "トイプーママさん"

  // 投稿内容
  content       String
  imageUrl      String?

  // 位置情報（市区町村レベルのみ）
  city          String    // "渋谷区", "横浜市"
  prefecture    String    // "東京都", "神奈川県"

  // カテゴリ
  category      String    // walk, dogrun, vet, trimming, lost, training, other

  // ステータス
  isHidden      Boolean   @default(false)  // 通報により非表示
  reportCount   Int       @default(0)

  // 統計
  likeCount     Int       @default(0)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // リレーション
  likes         PostLike[]
  reports       PostReport[]
}

model PostLike {
  id            String    @id @default(cuid())
  postId        String
  post          CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId        String

  createdAt     DateTime  @default(now())

  @@unique([postId, userId])  // 1ユーザー1いいね
}

model PostReport {
  id            String    @id @default(cuid())
  postId        String
  post          CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId        String

  // 通報理由
  reason        String    // inappropriate, spam, personal_info, medical, other
  detail        String?

  // ステータス
  status        String    @default("pending")  // pending, reviewed, dismissed
  reviewedAt    DateTime?

  createdAt     DateTime  @default(now())

  @@unique([postId, userId])  // 1ユーザー1通報
}

// ================================================
// 機能③：犬イベント情報（情報元URL付き）
// ================================================
// ================================================
// Apple In-App Purchase レシート履歴
// ================================================
model AppleReceipt {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  originalTransactionId String   @unique
  productId             String   // com.wansapo.premium.monthly
  purchaseDate          DateTime
  expiresDate           DateTime?
  isTrialPeriod         Boolean  @default(false)

  // 検証結果
  environment           String   // sandbox, production

  verifiedAt            DateTime @default(now())
  createdAt             DateTime @default(now())
}

model DogEvent {
  id            String    @id @default(cuid())

  // イベント基本情報
  title         String
  description   String

  // 日程
  startDate     DateTime
  endDate       DateTime?

  // 場所（市区町村レベル）
  venue         String    // 会場名
  address       String?
  city          String    // "渋谷区"
  prefecture    String    // "東京都"
  latitude      Float?
  longitude     Float?

  // カテゴリ
  category      String    // exhibition, party, meetup, competition, seminar, other

  // 情報元（必須）
  sourceUrl     String    // 情報元URL
  sourceName    String    // "〇〇公式サイト"

  // メタ情報
  imageUrl      String?
  fee           String?   // "無料", "1,000円"
  targetBreed   String?   // 対象犬種（あれば）

  // ステータス
  status        String    @default("upcoming")  // upcoming, ongoing, ended
  isActive      Boolean   @default(true)

  // 取得情報
  fetchedAt     DateTime  @default(now())

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
